# KIS (한국투자증권) API
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_BASE_URL=https://openapi.koreainvestment.com:9443
# KIS_ACCOUNT_NO: 주문/잔고 조회 시에만 필요, 시세 조회는 불필요
# ACCESS_TOKEN은 런타임에 APP_KEY + APP_SECRET으로 동적 발급 (24시간 유효), env 저장 불필요

# Prefect (self-hosted, NAS)
PREFECT_API_URL=http://192.168.45.147:4200/api

# PostgreSQL (NAS)
DB_HOST=192.168.45.147
DB_PORT=5432
DB_NAME=trading_db
DB_USER=
DB_PASSWORD=

# GitHub Container Registry (GHCR)
# 이미지: ghcr.io/<github-username>/personal-data-hub:latest
